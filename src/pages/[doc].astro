---
import { getCollection, render } from 'astro:content'

import { LANG } from '../i18n/config'
import { docPageT } from '../i18n/doc-page'
import FloatingHeader from '../components/ui/FloatingHeader.astro'
import BaseLayout from '../layouts/BaseLayout.astro'

const t = docPageT[LANG]

export async function getStaticPaths() {
  const docs = await getCollection('documents')
  return docs.map((doc) => ({
    params: { doc: doc.data.slug },
    props: { doc },
  }))
}

const { doc } = Astro.props
const { Content } = await render(doc)
const lead = t.leads[doc.data.slug as keyof typeof t.leads] ?? t.leads.default
---

<BaseLayout title={`${doc.data.title} | VigoTech`} description={doc.data.title}>
  <article class="doc-page mx-auto mt-4 w-full max-w-2xl px-6 pb-20 sm:mt-10">
    <FloatingHeader
      eyebrow={lead.badge}
      title={doc.data.title}
      showControls={false}
    />

    <header class="doc-hero mb-10">
      <p class="doc-lead">{lead.description}</p>
    </header>

    <section class="mb-10">
      <details class="doc-toc group" open>
        <summary class="doc-toc-summary">
          <span class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[#e84a5f]"
              >menu_book</span
            >
            <span class="font-headline text-sm font-bold tracking-wide"
              >{t.tocLabel}</span
            >
          </span>
          <span
            class="material-symbols-outlined text-slate-500 transition-transform duration-300 group-open:rotate-180"
          >
            expand_more
          </span>
        </summary>
        <nav class="doc-toc-links" data-doc-toc></nav>
      </details>
    </section>

    <div class="doc-content" data-doc-content>
      <div class="doc-content-inner">
        <Content />
      </div>
    </div>

    <section class="doc-report mt-12">
      <h2 class="font-headline text-2xl font-bold tracking-tight">
        {t.reportHeading}
      </h2>
      <p class="mt-3 text-sm leading-relaxed text-[var(--ink-soft)]">
        {t.reportDescription}
      </p>
      <div class="mt-6 flex items-center gap-4 flex-wrap">
        <a
          class="doc-report-button mt-6 inline-flex items-center gap-2"
          href="mailto:alliance@vigotech.org"
        >
          <span class="material-symbols-outlined text-base">send</span>
          {t.reportButton}
        </a>
        <a
          class="mt-4 inline-flex text-sm text-[var(--accent)] underline underline-offset-4"
          href={doc.data.sourceUrl}
          target="_blank"
        >
          {t.sourceMarkdown}
        </a>
      </div>
    </section>
  </article>

  <script is:inline>
    ;(() => {
      const content = document.querySelector('[data-doc-content]')
      const toc = document.querySelector('[data-doc-toc]')
      if (!content || !toc) return

      const slugify = (value) =>
        value
          .toLowerCase()
          .normalize('NFKD')
          .replace(/[\u0300-\u036f]/g, '')
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '')

      const headings = Array.from(content.querySelectorAll('h2, h3'))
      if (headings.length === 0) {
        toc.innerHTML = `<p class="text-sm text-slate-500">${t.noSections}</p>`
        return
      }

      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = `section-${index + 1}-${slugify(heading.textContent || 'section')}`
        }

        const link = document.createElement('a')
        link.href = `#${heading.id}`
        link.textContent = heading.textContent || t.fallbackSection
        link.className =
          heading.tagName === 'H2'
            ? 'doc-toc-link doc-toc-link-primary'
            : 'doc-toc-link doc-toc-link-secondary'
        toc.appendChild(link)
      })
    })()
  </script>
</BaseLayout>
