---
import type { CollectionEntry } from 'astro:content'
import { LANG } from '../../i18n/config'
import { homeFriendsT } from '../../i18n/home-friends'
import { withBase } from '../../lib/base-path'

type Props = {
  friends: Array<CollectionEntry<'friends'>>
}

const { friends } = Astro.props
const t = homeFriendsT[LANG]
---

{
  friends.length > 0 && (
    <section class='reveal mt-12' style='--reveal-delay: 210ms;'>
      <div class='vt-content-shell'>
        <header class='mb-4'>
          <h2 class='text-2xl font-semibold tracking-tight'>{t.heading}</h2>
        </header>
        <div class='grid gap-3 grid-cols-2 sm:grid-cols-3 md:grid-cols-5'>
          {friends.map((friend) => (
            <a class='vt-card flex min-h-30 items-center justify-center p-4' href={friend.data.link ?? '#'}>
              {friend.data.logo ? (
                <img src={withBase(friend.data.logo)} alt={friend.data.name} class='max-h-14 object-contain' loading='lazy' />
              ) : (
                <span class='text-sm text-[var(--ink-soft)]'>{friend.data.name}</span>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
