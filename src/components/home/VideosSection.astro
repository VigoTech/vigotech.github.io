---
import type { CollectionEntry } from 'astro:content'

import { LANG, LOCALE } from '../../i18n/config'
import { homeVideosT } from '../../i18n/home-videos'
import { withBase } from '../../lib/base-path'
import GroupLogo from '../ui/GroupLogo.astro'

type Props = {
  videos: Array<CollectionEntry<'videos'>>
}

const { videos } = Astro.props
const t = homeVideosT[LANG]

const formatDate = (value: number | null): string => {
  if (!value) {
    return ''
  }
  return new Intl.DateTimeFormat(LOCALE, {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  })
    .format(new Date(value))
    .replace(/\./g, '')
}
---

<section class='reveal py-16' style='--reveal-delay: 110ms;'>
  <div class='vt-content-shell'>
    <header class='mb-6 flex items-end justify-between gap-4'>
      <div>
        <p class='font-headline text-xs tracking-[0.12em] text-primary uppercase'>{t.eyebrow}</p>
        <h2 class='font-headline text-3xl tracking-tight sm:text-5xl'>{t.heading}</h2>
      </div>
      <a href={withBase('/videos')} class='text-sm font-semibold text-primary underline underline-offset-3'>
        {t.viewAll}
      </a>
    </header>

    <div class='grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3'>
      {
        videos.map((video) => (
          <article class='overflow-hidden rounded-2xl bg-[var(--bg-panel)]'>
            <a href={video.data.url ?? '#'} target='_blank' rel='noreferrer' class='block'>
              {video.data.thumbnail ? (
                <img
                  src={withBase(video.data.thumbnail)}
                  alt={video.data.title}
                  class='aspect-video w-full object-cover'
                  loading='lazy'
                />
              ) : (
                <div class='aspect-video w-full bg-[var(--bg-elevated)]' />
              )}
            </a>

            <div class='p-4'>
              <div class='mb-2 flex items-center gap-2'>
                <GroupLogo
                  src={video.data.groupLogo}
                  name={video.data.groupName}
                  sizeClass='size-7'
                  class='bg-white'
                  fallbackClass='text-[10px] font-semibold text-[var(--ink)]'
                />
                <span class='text-xs font-semibold tracking-[0.08em] text-primary uppercase'>
                  {video.data.groupName}
                </span>
              </div>

              <h3 class='font-headline text-lg leading-tight text-[var(--ink)]'>{video.data.title}</h3>

              <div class='mt-3 flex items-center justify-between'>
                <span class='text-xs text-[var(--ink-soft)]'>{formatDate(video.data.publishedAt)}</span>
                <a href={video.data.url ?? '#'} target='_blank' rel='noreferrer' class='text-sm font-semibold text-primary'>
                  {t.watchNow}
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
