---
import type { CollectionEntry } from 'astro:content'

import { LANG } from '../../i18n/config'
import { groupsT } from '../../i18n/groups'
import FloatingHeader from '../ui/FloatingHeader.astro'
import GroupCard from './GroupCard.astro'

type Props = {
  groups: Array<CollectionEntry<'groups'>>
}

const { groups } = Astro.props
const t = groupsT[LANG]

const filterOptions = [
  { id: 'active', label: t.filterActive },
  { id: 'inactive', label: t.filterInactive },
  { id: 'all', label: t.filterAll },
]
---

<section class='vt-content-shell mt-6 px-2 pb-20 sm:px-6'>
  <FloatingHeader
    eyebrow={t.directoryEyebrow}
    title={t.directoryTitle}
    searchPlaceholder={t.searchPlaceholder}
    filters={filterOptions}
    activeFilterId='all'
    eventName='vt:groups-filters-change'
  />

  <div class='grid gap-3 [grid-template-columns:repeat(auto-fit,minmax(240px,1fr))]' data-groups-grid>
    {
      groups.map((group) => (
        <div data-group-card data-group-name={group.data.name.toLowerCase()} data-group-inactive={group.data.inactive ? 'true' : 'false'}>
          <GroupCard group={group} showStatus={true} />
        </div>
      ))
    }
  </div>

  <p class='mt-6 hidden text-sm text-[var(--ink-soft)]' data-groups-empty>{t.emptyResults}</p>
</section>

<script is:inline>
  (() => {
    const cards = Array.from(document.querySelectorAll('[data-group-card]'))
    const empty = document.querySelector('[data-groups-empty]')
    const stickyFilters = document.querySelector('[data-sticky-event="vt:groups-filters-change"]')

    if (!(stickyFilters instanceof HTMLElement) || cards.length === 0) {
      return
    }

    let mode = 'all'
    let query = ''

    const update = () => {
      let visibleCount = 0

      cards.forEach((card) => {
        const name = card.getAttribute('data-group-name') || ''
        const inactive = card.getAttribute('data-group-inactive') === 'true'

        const byMode =
          mode === 'all' ||
          (mode === 'active' && !inactive) ||
          (mode === 'inactive' && inactive)
        const byQuery = query.length === 0 || name.includes(query)
        const visible = byMode && byQuery

        card.classList.toggle('hidden', !visible)
        if (visible) {
          visibleCount += 1
        }
      })

      if (empty) {
        empty.classList.toggle('hidden', visibleCount > 0)
      }
    }

    stickyFilters.addEventListener('vt:groups-filters-change', (event) => {
      const detail = event.detail || {}

      mode = detail.activeFilterId || 'all'
      query = (detail.searchValue || '').trim().toLowerCase()
      update()
    })

    update()
  })()
</script>
