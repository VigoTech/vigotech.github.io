<canvas
  id="hero-shader-canvas"
  aria-hidden="true"
  style="position:absolute;inset:0;width:100%;height:100%;display:block;pointer-events:none;"
></canvas>

<script>
  import { createRendererFromJSON } from 'shaders/core'

  async function initShader() {
    const canvas = document.getElementById('hero-shader-canvas')
    if (!canvas || !(canvas instanceof HTMLCanvasElement)) {
      return
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return
    }

    const renderer = createRendererFromJSON({
      components: [
        {
          type: 'LinearGradient',
          id: 'hero_lg',
          props: {
            colorA: '#fd969d',
            colorB: '#d9e4e9',
            colorSpace: 'oklch',
            edges: 'mirror',
            start: { x: 0.18, y: 0.68 },
            end: { x: 0.82, y: 0.22 },
            angle: 0,
          },
        },
        {
          type: 'Blob',
          id: 'hero_blob',
          props: {
            colorA: '#b11f3b',
            colorB: '#d33b51',
            colorSpace: 'oklch',
            size: 1,
            deformation: 0.92,
            softness: 2,
            speed: 0.75,
            highlightIntensity: 0.28,
            highlightX: 0.28,
            highlightY: -0.25,
            highlightZ: 0.32,
            highlightColor: '#ff8ca3',
            seed: 3,
            center: { x: 0.5, y: 0.5 },
            blendMode: 'normal-oklch',
          },
        },
        {
          type: 'DotGrid',
          id: 'hero_dotgrid',
          props: {
            color: '#333',
            density: 44,
            dotSize: 0.2,
            twinkle: 0.1,
          },
        },
        {
          type: 'Liquify',
          id: 'hero_liquify',
          props: {
            intensity: 1.6,
            decay: 1,
            radius: 2,
            edges: 'mirror',
          },
        },
        {
          type: 'FilmGrain',
          id: 'hero_grain',
          props: {
            strength: 0.07,
          },
        },
      ],
    })

    await renderer.initialize(canvas)

    let active = true
    const loop = async () => {
      if (!active) {
        return
      }
      await renderer.renderFrame()
      requestAnimationFrame(loop)
    }
    requestAnimationFrame(loop)

    const cleanup = () => {
      active = false
      renderer.dispose()
      window.removeEventListener('beforeunload', cleanup)
    }
    window.addEventListener('beforeunload', cleanup)
  }

  initShader().catch(() => {
    // Progressive enhancement only
  })
</script>
